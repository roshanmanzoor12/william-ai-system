  "action_rules": [
    {
      "rule_id": "RULE-0001",
      "name": "Require user and workspace for scoped actions",
      "match": {
        "scoped": true
      },
      "decision": "require_context",
      "required_fields": [
        "user_id",
        "workspace_id"
      ],
      "severity": "critical"
    },
    {
      "rule_id": "RULE-0002",
      "name": "Block cross-workspace data access",
      "match": {
        "action_tags": [
          "workspace_data"
        ],
        "target_workspace_differs_from_context": true
      },
      "decision": "deny",
      "severity": "critical"
    },
    {
      "rule_id": "RULE-0003",
      "name": "Block cross-user private data access",
      "match": {
        "action_tags": [
          "user_private_data"
        ],
        "target_user_differs_from_context": true
      },
      "decision": "deny",
      "severity": "critical"
    },
    {
      "rule_id": "RULE-0004",
      "name": "Require approval for destructive actions",
      "match": {
        "action_tags": [
          "destructive"
        ]
      },
      "decision": "approval_required",
      "severity": "critical"
    },
    {
      "rule_id": "RULE-0005",
      "name": "Require approval for external communications",
      "match": {
        "action_tags": [
          "external_communication"
        ]
      },
      "decision": "approval_required",
      "severity": "high"
    },
    {
      "rule_id": "RULE-0006",
      "name": "Require approval for financial actions",
      "match": {
        "action_tags": [
          "financial_execution"
        ]
      },
      "decision": "approval_required",
      "severity": "critical"
    },
    {
      "rule_id": "RULE-0007",
      "name": "Require approval for code execution",
      "match": {
        "action_tags": [
          "code_execution"
        ]
      },
      "decision": "approval_required",
      "severity": "critical"
    },
    {
      "rule_id": "RULE-0008",
      "name": "Require approval for browser form submission",
      "match": {
        "action_tags": [
          "browser_form_submission"
        ]
      },
      "decision": "approval_required",
      "severity": "high"
    },
    {
      "rule_id": "RULE-0009",
      "name": "Never allow raw secret logging",
      "match": {
        "action_tags": [
          "secret_logging"
        ]
      },
      "decision": "deny",
      "severity": "critical"
    },
    {
      "rule_id": "RULE-0010",
      "name": "Require sanitized memory payload",
      "match": {
        "action_tags": [
          "memory_write"
        ]
      },
      "decision": "require_sanitization",
      "severity": "high"
    },
    {
      "rule_id": "RULE-0011",
      "name": "Verification payload required",
      "match": {
        "action_completed": true
      },
      "decision": "require_verification_payload",
      "severity": "medium"
    },
    {
      "rule_id": "RULE-0012",
      "name": "Audit required for sensitive actions",
      "match": {
        "sensitivity": [
          "medium",
          "high",
          "critical",
          "blocked"
        ]
      },
      "decision": "require_audit_log",
      "severity": "high"
    },
    {
      "rule_id": "RULE-0013",
      "name": "Deny unknown critical actions by default",
      "match": {
        "action_known": false,
        "estimated_sensitivity": [
          "high",
          "critical"
        ]
      },
      "decision": "review_required",
      "severity": "high"
    },
    {
      "rule_id": "RULE-0014",
      "name": "Deny blocked actions",
      "match": {
        "action_in_blocked_list": true
      },
      "decision": "deny",
      "severity": "critical"
    },
    {
      "rule_id": "RULE-0015",
      "name": "Subscription must allow requested sensitivity",
      "match": {
        "subscription_enforced": true
      },
      "decision": "require_subscription_permission",
      "severity": "high"
    }
  ],
