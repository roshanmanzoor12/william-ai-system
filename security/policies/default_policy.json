{
  "policy_metadata": {
    "policy_name": "William Jarvis Default Global Security Policy",
    "policy_id": "william.security.default_policy.v1",
    "version": "1.0.0",
    "project": "William / Jarvis Multi-Agent AI SaaS System",
    "company": "Digital Promotix",
    "file_path": "security/policies/default_policy.json",
    "purpose": "Default global policy rules for blocked, sensitive, approval-required, and allowed actions.",
    "status": "active",
    "environment": "all",
    "last_updated": "2026-07-05",
    "contains_secrets": false,
    "safe_for_import": true,
    "compatible_with": {
      "master_agent": true,
      "security_agent": true,
      "verification_agent": true,
      "memory_agent": true,
      "agent_registry": true,
      "agent_loader": true,
      "agent_router": true,
      "dashboard_api": true,
      "fastapi": true,
      "multi_tenant_saas": true
    }
  },
  "global_principles": {
    "safety_first": true,
    "saas_isolation_required": true,
    "least_privilege_default": true,
    "deny_by_default_for_unknown_sensitive_actions": true,
    "allow_read_only_safe_actions_by_default": true,
    "require_user_id_for_user_scoped_actions": true,
    "require_workspace_id_for_workspace_scoped_actions": true,
    "never_mix_user_data": true,
    "never_mix_workspace_data": true,
    "never_log_raw_secrets": true,
    "never_store_plaintext_sensitive_data_in_memory": true,
    "never_execute_destructive_actions_without_approval": true,
    "never_execute_financial_actions_without_approval": true,
    "never_send_messages_calls_or_emails_without_approval": true,
    "never_access_external_browser_without_permission": true,
    "verification_payload_required_for_completed_actions": true,
    "audit_log_required_for_sensitive_actions": true,
    "memory_payload_must_be_sanitized": true
  },
  "default_decision": {
    "unknown_action": "review_required",
    "unknown_agent": "review_required",
    "unknown_role": "deny",
    "missing_user_id_when_required": "deny",
    "missing_workspace_id_when_required": "deny",
    "missing_subscription_when_required": "deny",
    "missing_agent_permission": "deny",
    "failed_security_check": "deny",
    "failed_policy_validation": "deny",
    "failed_context_validation": "deny"
  },
  "context_requirements": {
    "all_user_scoped_actions": {
      "required_fields": [
        "user_id"
      ],
      "on_missing": "deny",
      "reason": "User-scoped operations must identify the SaaS user to prevent data leakage."
    },
    "all_workspace_scoped_actions": {
      "required_fields": [
        "user_id",
        "workspace_id"
      ],
      "on_missing": "deny",
      "reason": "Workspace-scoped operations must identify both user and workspace to prevent cross-tenant data mixing."
    },
    "sensitive_actions": {
      "required_fields": [
        "user_id",
        "workspace_id",
        "request_id"
      ],
      "recommended_fields": [
        "role",
        "subscription_plan",
        "agent_name",
        "source_agent",
        "ip_address",
        "user_agent",
        "trace_id"
      ],
      "on_missing_required": "deny",
      "reason": "Sensitive actions require traceable SaaS context."
    },
    "system_level_actions": {
      "required_fields": [
        "request_id",
        "source_agent"
      ],
      "recommended_fields": [
        "trace_id",
        "admin_user_id",
        "workspace_id",
        "environment"
      ],
      "on_missing_required": "review_required",
      "reason": "System actions require traceability even when not tied to one workspace."
    }
  },
  "roles": {
    "owner": {
      "description": "Workspace owner with highest normal workspace-level privileges.",
      "inherits": [
        "admin"
      ],
      "can_request_sensitive_actions": true,
      "can_approve_sensitive_actions": true,
      "can_manage_workspace_users": true,
      "can_manage_agent_permissions": true,
      "can_manage_billing": true,
      "can_export_workspace_data": true
    },
    "admin": {
      "description": "Workspace administrator.",
      "inherits": [
        "manager"
      ],
      "can_request_sensitive_actions": true,
      "can_approve_sensitive_actions": true,
      "can_manage_workspace_users": true,
      "can_manage_agent_permissions": true,
      "can_manage_billing": false,
      "can_export_workspace_data": true
    },
    "manager": {
      "description": "Team manager with operational access.",
      "inherits": [
        "member"
      ],
      "can_request_sensitive_actions": true,
      "can_approve_sensitive_actions": false,
      "can_manage_workspace_users": false,
      "can_manage_agent_permissions": false,
      "can_manage_billing": false,
      "can_export_workspace_data": false
    },
    "member": {
      "description": "Standard workspace user.",
      "inherits": [
        "viewer"
      ],
      "can_request_sensitive_actions": true,
      "can_approve_sensitive_actions": false,
      "can_manage_workspace_users": false,
      "can_manage_agent_permissions": false,
      "can_manage_billing": false,
      "can_export_workspace_data": false
    },
    "viewer": {
      "description": "Read-only user.",
      "inherits": [],
      "can_request_sensitive_actions": false,
      "can_approve_sensitive_actions": false,
      "can_manage_workspace_users": false,
      "can_manage_agent_permissions": false,
      "can_manage_billing": false,
      "can_export_workspace_data": false
    },
    "service_account": {
      "description": "Internal service identity for controlled automation.",
      "inherits": [],
      "can_request_sensitive_actions": true,
      "can_approve_sensitive_actions": false,
      "can_manage_workspace_users": false,
      "can_manage_agent_permissions": false,
      "can_manage_billing": false,
      "can_export_workspace_data": false,
      "requires_explicit_scope": true,
      "requires_agent_permission": true
    },
    "super_admin": {
      "description": "Platform-level administrator. Must be tightly restricted and audited.",
      "inherits": [
        "owner"
      ],
      "can_request_sensitive_actions": true,
      "can_approve_sensitive_actions": true,
      "can_manage_platform_policy": true,
      "can_manage_all_workspaces": true,
      "requires_mfa": true,
      "requires_strong_audit": true,
      "allowed_only_in_admin_context": true
    }
  },
  "subscription_plans": {
    "free": {
      "description": "Limited plan for basic non-sensitive usage.",
      "allowed_sensitivity_levels": [
        "low"
      ],
      "blocked_agent_categories": [
        "finance_execution",
        "call_execution",
        "external_browser_execution",
        "bulk_message_execution",
        "system_execution"
      ],
      "max_daily_sensitive_requests": 0
    },
    "starter": {
      "description": "Starter SaaS plan.",
      "allowed_sensitivity_levels": [
        "low",
        "medium"
      ],
      "blocked_agent_categories": [
        "finance_execution",
        "system_execution"
      ],
      "max_daily_sensitive_requests": 25
    },
    "professional": {
      "description": "Professional plan for normal business automation.",
      "allowed_sensitivity_levels": [
        "low",
        "medium",
        "high"
      ],
      "blocked_agent_categories": [
        "unrestricted_system_execution",
        "unapproved_finance_execution"
      ],
      "max_daily_sensitive_requests": 250
    },
    "business": {
      "description": "Business plan with higher operational limits.",
      "allowed_sensitivity_levels": [
        "low",
        "medium",
        "high"
      ],
      "blocked_agent_categories": [
        "unrestricted_system_execution",
        "unapproved_finance_execution"
      ],
      "max_daily_sensitive_requests": 1000
    },
    "enterprise": {
      "description": "Enterprise plan with custom approval workflows.",
      "allowed_sensitivity_levels": [
        "low",
        "medium",
        "high",
        "critical_with_approval"
      ],
      "blocked_agent_categories": [
        "unrestricted_system_execution"
      ],
      "max_daily_sensitive_requests": 10000,
      "supports_custom_policy_overrides": true
    }
  },
  "sensitivity_levels": {
    "low": {
      "description": "Safe read-only or non-sensitive operations.",
      "security_check_required": false,
      "audit_required": false,
      "verification_required": true,
      "approval_required": false
    },
    "medium": {
      "description": "Actions that read user/workspace data or modify non-critical state.",
      "security_check_required": true,
      "audit_required": true,
      "verification_required": true,
      "approval_required": false
    },
    "high": {
      "description": "Actions involving sensitive data, external systems, memory changes, secrets, files, messages, calls, browsing, or billing metadata.",
      "security_check_required": true,
      "audit_required": true,
      "verification_required": true,
      "approval_required": true
    },
    "critical": {
      "description": "Destructive, financial, system-level, credential, policy, or irreversible actions.",
      "security_check_required": true,
      "audit_required": true,
      "verification_required": true,
      "approval_required": true,
      "mfa_recommended": true,
      "manual_review_recommended": true
    },
    "blocked": {
      "description": "Actions that are never allowed under the default policy.",
      "security_check_required": true,
      "audit_required": true,
      "verification_required": true,
      "approval_required": false,
      "always_deny": true
    }
  },
