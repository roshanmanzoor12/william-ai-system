{
  "name": "william-jarvis-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "William / Jarvis Multi-Agent AI SaaS Dashboard by Digital Promotix - Frontend App Router Dashboard",
  "author": "Digital Promotix",
  "license": "PROPRIETARY",
  "packageManager": "npm@10.2.0",
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run type-check && npm run lint && npm run format:check",
    "clean": "rimraf .next node_modules package-lock.json",
    "clean:build": "rimraf .next",
    "reinstall": "npm run clean && npm install",
    "postinstall": "next telemetry disable"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.1",
    "axios": "^1.6.8",
    "clsx": "^2.1.1",
