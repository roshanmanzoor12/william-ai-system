# William / Jarvis Dashboard -- Digital Promotix
# Copy to .env.local for local development. Next.js only exposes vars
# prefixed NEXT_PUBLIC_* to the browser bundle.

# Base URL of the FastAPI backend, including the /api/v1 prefix.
# apps/dashboard/src/lib/api.ts falls back to same-origin "/api/v1" if unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
