# LLM / knowledge provider (core/llm_provider.py) -- unset means an honest
# "knowledge provider is not connected yet" reply naming Ollama/OpenAI/LM
# Studio as the way to connect one; live/current data (weather,
# news, stock prices) is never answered from the LLM regardless of this
# setting, see core/llm_provider.py::is_live_data_query. One OpenAI-
# compatible /chat/completions code path serves all three cases below:
#   - WILLIAM_LLM_PROVIDER=openai, WILLIAM_LLM_BASE_URL=https://api.openai.com/v1,
#     WILLIAM_LLM_API_KEY=<real key>, WILLIAM_LLM_MODEL=gpt-4o-mini
#   - WILLIAM_LLM_PROVIDER=ollama, WILLIAM_LLM_BASE_URL=http://localhost:11434/v1,
#     WILLIAM_LLM_MODEL=llama3.1 (WILLIAM_LLM_API_KEY not required locally)
#   - WILLIAM_LLM_PROVIDER=lmstudio, WILLIAM_LLM_BASE_URL=http://localhost:1234/v1,
#     WILLIAM_LLM_MODEL=<model loaded in LM Studio> (no API key required)
WILLIAM_LLM_API_KEY=
WILLIAM_LLM_BASE_URL=
WILLIAM_LLM_MODEL=
WILLIAM_LLM_PROVIDER=
# Speaker recognition provider for Trusted Voice Profiles -- real, local
# spectral-fingerprint embedding computed on the Voice Worker (apps/
# worker_nodes/voice/providers/speaker_embedding.py) when set to
# "local_speaker_embedding"; unset means honest external_dependency_
# required (normal commands still work; sensitive commands require
# dashboard approval -- server-side admin/owner or profile-based
# authorization always applies either way).
WILLIAM_SPEAKER_RECOGNITION_PROVIDER=
# Real Fernet key (Fernet.generate_key()) used to encrypt Trusted Voice
# Profile embeddings at rest (apps/api/services/voice_embedding_crypto.py)
# -- unset means a per-process EPHEMERAL key (dev-only; enrolled profiles
# need re-enrollment after every restart). Set this explicitly in
# production.
WILLIAM_VOICE_EMBEDDING_KEY=
# Minimum cosine-similarity confidence for a captured voice to count as a
# match against an enrolled Trusted Voice Profile.
WILLIAM_VOICE_MATCH_THRESHOLD=0.72
# Speech-to-text provider (apps/api/routes/voice.py::compute_dependency_status,
# apps/worker_nodes/voice/providers/stt.py) -- unset (or "none") means
# honest external_dependency_required; typed/simulated text commands never
# need this. WILLIAM_STT_PROVIDER=faster_whisper (or the identical aliases
# local_whisper / faster_whisper_local / whisper_local) runs 100% locally
# (no API key needed) once the faster-whisper package is installed;
# WILLIAM_STT_DEVICE/WILLIAM_STT_COMPUTE_TYPE only apply to that local
# provider.
# WILLIAM_STT_BASE_URL/WILLIAM_STT_API_KEY are for an OpenAI-compatible
# remote STT provider instead (e.g. WILLIAM_STT_PROVIDER=openai against
# api.openai.com's /audio/transcriptions).
WILLIAM_STT_API_KEY=
WILLIAM_STT_BASE_URL=
WILLIAM_STT_COMPUTE_TYPE=int8
WILLIAM_STT_DEVICE=cpu
# Pins a language code (e.g. "en") for the local faster-whisper provider
# instead of its default per-clip auto-detection; blank keeps auto-detect.
WILLIAM_STT_LANGUAGE=
WILLIAM_STT_MODEL=base
WILLIAM_STT_PROVIDER=
# Text-to-speech provider (apps/worker_nodes/voice/providers/tts.py) --
# unset means responses are text-only (speech_output_status: tts_missing),
# never a fake "spoken" claim, and never blocks real-listening mode either
# way. WILLIAM_TTS_PROVIDER=pyttsx3 (or the identical alias
# pyttsx3_local) runs 100% locally (Windows SAPI voices, no API key).
# WILLIAM_TTS_BASE_URL/WILLIAM_TTS_API_KEY are for a remote TTS provider
# instead.
WILLIAM_TTS_API_KEY=
WILLIAM_TTS_BASE_URL=
WILLIAM_TTS_MODEL=
WILLIAM_TTS_PROVIDER=
WILLIAM_TTS_RATE=175
WILLIAM_TTS_VOICE=
WILLIAM_TTS_VOLUME=1.0
WILLIAM_UVICORN_LOG_LEVEL=info
WILLIAM_VERIFICATION_AGENT_ENABLED=
# Real *audio* wake-word engine for always-listening microphone mode,
# distinct from the always-available text-based wake-word detection
# (agents/voice_agent/wake_word.py, needs no provider) that
# --simulate-text and push-to-talk already use.
# WILLIAM_WAKE_WORD_PROVIDER=openwakeword (or the identical alias
# openwakeword_local) once the openwakeword package is installed.
WILLIAM_WAKE_WORD_MODEL=
WILLIAM_WAKE_WORD_PHRASE=William
WILLIAM_WAKE_WORD_PROVIDER=
WILLIAM_WEBHOOK_SECRET_PEPPER=
