# ============================================================
# William / Jarvis Multi-Agent AI SaaS System
# Digital Promotix
# File: .env.example
#
# Purpose:
#   Real, code-accurate environment variable template. Generated by
#   scanning every os.getenv()/os.environ.get() call in this repository
#   (core/, agents/, apps/api, database/, security/, subscriptions/,
#   main.py) so this file matches what the code actually reads.
#
#   Copy this file to .env and fill in real values. Never commit .env.
#
# Notes:
#   - Blank value = the code falls back to a safe built-in default
#     (see the referenced module for the exact default) if the var is
#     unset. You do not have to set every variable to run locally.
#   - Vars in the CRITICAL SECRETS section below have NO safe default
#     and must be set with real, randomly generated values before any
#     production deployment. Generate with, e.g.:
#       python -c "import secrets; print(secrets.token_urlsafe(48))"
#   - Every WILLIAM_*-prefixed name is also accepted with a
#     JARVIS_ / DIGITAL_PROMOTIX_ / DP_ prefix instead
#     (security/secrets_manager.py DEFAULT_ENV_PREFIXES), and most
#     also work unprefixed. WILLIAM_* is the documented convention.
# ============================================================


# ============================================================
# 0. CRITICAL SECRETS -- no safe default, required before production
# ============================================================

# Signs/verifies API JWTs (apps/api/routes/auth.py TokenService).
# Dev-only fallback exists but apps/api refuses it once WILLIAM_ENV=production.
WILLIAM_JWT_SECRET=

# AES-256-GCM master key for security/encryption.py. If unset, every
# encrypt/decrypt call fails closed (ENCRYPTION_KEY_NOT_CONFIGURED) --
# this is intentional, not a bug.
WILLIAM_ENCRYPTION_KEY=
WILLIAM_ENCRYPTION_KEY_ID=default

# HMAC key used to sign audit log entries so they can be tamper-checked later.
WILLIAM_AUDIT_SIGNING_KEY=

# Used to derive stable per-device fingerprints (system/browser worker trust).
WILLIAM_DEVICE_FINGERPRINT_SECRET=

# HMAC pepper for verifying inbound workflow webhook signatures.
WILLIAM_WEBHOOK_SECRET_PEPPER=

# Signs internal event-bus payloads (notifications/dashboard websocket).
WILLIAM_INTERNAL_EVENT_SIGNING_SECRET=


# ============================================================
# 1. DATABASE (database/db.py)
# ============================================================

# SQLAlchemy URL. Falls back to sqlite:///./william.db if unset -- fine
# for local dev, not for production (see docker-compose.yml postgres service).
DATABASE_URL=sqlite:///./william.db
# Alternate name db.py also accepts:
POSTGRES_URL=
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=1800
WILLIAM_ALLOW_SQLITE_FALLBACK=true


# ============================================================
# 2. DASHBOARD FRONTEND (apps/dashboard -- read at build/runtime by Next.js)
# See apps/dashboard/.env.example for the frontend-local copy of this.
# ============================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1


