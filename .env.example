# ============================================================
# William / Jarvis Multi-Agent AI SaaS System
# Digital Promotix
# File: .env.example
# Purpose:
# Safe environment variable template with NO real secrets.
# Copy this file to .env and replace placeholder values.
# ============================================================


# ============================================================
# 1. APPLICATION CORE
# ============================================================

APP_NAME="William AI"
APP_ENV="development"
APP_DEBUG=true
APP_VERSION="1.0.0"

APP_HOST="0.0.0.0"
APP_PORT=8000

APP_BASE_URL="http://localhost:8000"
FRONTEND_BASE_URL="http://localhost:3000"

API_PREFIX="/api"
TIMEZONE="Asia/Karachi"

# Allowed values:
# development | staging | production
ENVIRONMENT="development"


# ============================================================
# 2. SECURITY SETTINGS
# ============================================================

# Generate strong random values before production.
SECRET_KEY="replace_with_secure_random_secret_key"
JWT_SECRET_KEY="replace_with_secure_random_jwt_secret"
JWT_ALGORITHM="HS256"

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

PASSWORD_HASH_SCHEME="bcrypt"

# Security Agent approval settings
SECURITY_AGENT_ENABLED=true
SECURITY_APPROVAL_REQUIRED_FOR_SENSITIVE_ACTIONS=true
SECURITY_APPROVAL_TIMEOUT_SECONDS=120

# Sensitive action examples:
# system_command, browser_action, payment_action, call_action,
# file_delete, user_data_export, workspace_admin_change
SENSITIVE_ACTIONS="system_command,browser_action,payment_action,call_action,file_delete,user_data_export,workspace_admin_change"

# CORS
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_METHODS="GET,POST,PUT,PATCH,DELETE,OPTIONS"
CORS_ALLOWED_HEADERS="Authorization,Content-Type,X-Workspace-ID,X-User-ID"


# ============================================================
# 3. DATABASE CONFIGURATION
# ============================================================

DATABASE_ENGINE="postgresql"

# PostgreSQL example:
DATABASE_URL="postgresql+psycopg2://william_user:william_password@localhost:5432/william_ai"

# SQLite fallback for local development:
SQLITE_DATABASE_URL="sqlite:///./william_ai.db"

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

# Run migrations safely
AUTO_RUN_MIGRATIONS=false


# ============================================================
# 4. REDIS / CACHE / QUEUE
# ============================================================

REDIS_ENABLED=true
REDIS_URL="redis://localhost:6379/0"

CACHE_TTL_SECONDS=300

TASK_QUEUE_BACKEND="redis"
TASK_QUEUE_NAME="william_tasks"

BACKGROUND_WORKERS_ENABLED=true
BACKGROUND_WORKER_CONCURRENCY=4


# ============================================================
# 5. SAAS USER / WORKSPACE ISOLATION
# ============================================================

SAAS_MODE_ENABLED=true

DEFAULT_WORKSPACE_NAME="Default Workspace"
DEFAULT_USER_ROLE="owner"

# Never allow cross-workspace data leakage
ENFORCE_WORKSPACE_ISOLATION=true
ENFORCE_USER_CONTEXT=true

# Headers used by dashboard/API requests
USER_CONTEXT_HEADER="X-User-ID"
WORKSPACE_CONTEXT_HEADER="X-Workspace-ID"

# Role system
SUPPORTED_ROLES="owner,admin,manager,member,viewer"

# Subscription plans
SUPPORTED_PLANS="free,starter,pro,business,enterprise"

DEFAULT_PLAN="free"


# ============================================================
# 6. MASTER AGENT CONFIGURATION
# ============================================================

MASTER_AGENT_ENABLED=true
MASTER_AGENT_NAME="William"

MASTER_AGENT_REQUIRE_USER_CONTEXT=true
MASTER_AGENT_REQUIRE_WORKSPACE_CONTEXT=true

MASTER_AGENT_ROUTING_MODE="registry"

# Allowed values:
# registry | router | hybrid
AGENT_ROUTING_MODE="hybrid"

MASTER_AGENT_MAX_TASK_CHAIN_DEPTH=10
MASTER_AGENT_TIMEOUT_SECONDS=120

MASTER_AGENT_ENABLE_AUDIT_LOGS=true
MASTER_AGENT_ENABLE_MEMORY_PAYLOADS=true
MASTER_AGENT_ENABLE_VERIFICATION_PAYLOADS=true


# ============================================================
# 7. AGENT REGISTRY / LOADER / ROUTER
# ============================================================

AGENT_REGISTRY_ENABLED=true
AGENT_AUTO_DISCOVERY_ENABLED=true
AGENT_PLUGIN_MODE_ENABLED=true

AGENT_MODULE_BASE_PATH="agents"

AGENT_LOAD_TIMEOUT_SECONDS=30
AGENT_EXECUTION_TIMEOUT_SECONDS=180

# If true, failed optional agents do not crash the full app.
AGENT_SAFE_IMPORTS_ENABLED=true

# Built-in agents
ENABLED_AGENTS="master,voice,system,browser,code,memory,security,verification,visual,workflow,hologram,call,business,finance,creator"

DISABLED_AGENTS=""

# Future plugin agents path
PLUGIN_AGENT_PATH="plugins/agents"


# ============================================================
# 8. BASE AGENT STANDARD RESULT SETTINGS
# ============================================================

AGENT_RESULT_FORMAT="structured_json"

AGENT_RESULT_REQUIRE_SUCCESS_FIELD=true
AGENT_RESULT_REQUIRE_MESSAGE_FIELD=true
AGENT_RESULT_REQUIRE_DATA_FIELD=true
AGENT_RESULT_REQUIRE_ERROR_FIELD=true
AGENT_RESULT_REQUIRE_METADATA_FIELD=true

AGENT_EVENT_EMITTER_ENABLED=true
AGENT_AUDIT_LOGGING_ENABLED=true
AGENT_MEMORY_PAYLOAD_ENABLED=true
AGENT_VERIFICATION_PAYLOAD_ENABLED=true


# ============================================================
# 9. MEMORY AGENT CONFIGURATION
# ============================================================

MEMORY_AGENT_ENABLED=true

MEMORY_STORAGE_BACKEND="database"

# Allowed values:
# database | vector | hybrid
MEMORY_MODE="hybrid"

MEMORY_REQUIRE_USER_ID=true
MEMORY_REQUIRE_WORKSPACE_ID=true

MEMORY_MAX_CONTEXT_ITEMS=50
MEMORY_CONTEXT_TTL_DAYS=365

MEMORY_ALLOW_PERSONALIZATION=true
MEMORY_ALLOW_LONG_TERM_MEMORY=true

# Never mix memories between users/workspaces
MEMORY_ENFORCE_USER_ISOLATION=true
MEMORY_ENFORCE_WORKSPACE_ISOLATION=true

# Vector database placeholders
VECTOR_DB_PROVIDER="none"
VECTOR_DB_URL="replace_with_vector_database_url"
VECTOR_DB_API_KEY="replace_with_vector_database_api_key"

EMBEDDING_MODEL="text-embedding-3-small"


# ============================================================
# 10. SECURITY AGENT CONFIGURATION
# ============================================================

SECURITY_AGENT_NAME="Security Agent"

SECURITY_RISK_SCORING_ENABLED=true
SECURITY_MAX_ALLOWED_RISK_SCORE=70

SECURITY_BLOCK_HIGH_RISK_ACTIONS=true
SECURITY_LOG_ALL_SENSITIVE_ACTIONS=true

SECURITY_REQUIRE_APPROVAL_FOR_SYSTEM_COMMANDS=true
SECURITY_REQUIRE_APPROVAL_FOR_BROWSER_ACTIONS=true
SECURITY_REQUIRE_APPROVAL_FOR_CALL_ACTIONS=true
SECURITY_REQUIRE_APPROVAL_FOR_PAYMENT_ACTIONS=true
SECURITY_REQUIRE_APPROVAL_FOR_FILE_DELETE=true

SECURITY_ALLOWED_SYSTEM_COMMANDS=""

SECURITY_BLOCKED_SYSTEM_COMMANDS="rm -rf,format,diskpart,shutdown,reboot,del /f,reg delete"

SECURITY_ENABLE_RATE_LIMITING=true
SECURITY_RATE_LIMIT_REQUESTS=100
SECURITY_RATE_LIMIT_WINDOW_SECONDS=60


# ============================================================
# 11. VERIFICATION AGENT CONFIGURATION
# ============================================================

VERIFICATION_AGENT_ENABLED=true

VERIFICATION_REQUIRE_PAYLOAD_AFTER_ACTION=true
VERIFICATION_STORE_RESULTS=true

VERIFICATION_CONFIDENCE_THRESHOLD=0.75

VERIFICATION_ENABLE_TASK_SUMMARY=true
VERIFICATION_ENABLE_OUTPUT_VALIDATION=true
VERIFICATION_ENABLE_ACTION_CONFIRMATION=true


# ============================================================
# 12. VOICE AGENT CONFIGURATION
# ============================================================

VOICE_AGENT_ENABLED=true

WAKE_WORD_ENABLED=true
WAKE_WORD="William"

STT_PROVIDER="local"
TTS_PROVIDER="local"

# Examples:
# openai | whisper | google | azure | local
VOICE_STT_ENGINE="local"

# Examples:
# openai | elevenlabs | azure | local
VOICE_TTS_ENGINE="local"

VOICE_LANGUAGE_AUTO_DETECT=true
VOICE_DEFAULT_LANGUAGE="en"

VOICE_ALLOW_INTERRUPTION=true
VOICE_BACKGROUND_LISTENING=false

VOICE_MIC_DEVICE="default"
VOICE_SPEAKER_DEVICE="default"

VOICE_AUDIO_SAMPLE_RATE=16000


# ============================================================
# 13. SYSTEM AGENT CONFIGURATION
# ============================================================

SYSTEM_AGENT_ENABLED=true

SYSTEM_AGENT_ALLOW_READ_ONLY_SYSTEM_INFO=true
SYSTEM_AGENT_ALLOW_SYSTEM_COMMANDS=false

SYSTEM_AGENT_REQUIRE_SECURITY_APPROVAL=true

SYSTEM_AGENT_SUPPORTED_PLATFORMS="windows,macos,linux,android,ios"

SYSTEM_AGENT_COMMAND_TIMEOUT_SECONDS=30


# ============================================================
# 14. BROWSER AGENT CONFIGURATION
# ============================================================

BROWSER_AGENT_ENABLED=true

BROWSER_HEADLESS=true
BROWSER_PROVIDER="playwright"

BROWSER_TIMEOUT_SECONDS=60
BROWSER_MAX_TABS=5

BROWSER_REQUIRE_SECURITY_APPROVAL_FOR_LOGIN=true
BROWSER_REQUIRE_SECURITY_APPROVAL_FOR_PURCHASES=true
BROWSER_REQUIRE_SECURITY_APPROVAL_FOR_FORMS=true

BROWSER_DEFAULT_USER_AGENT="WilliamAI/1.0"

BROWSER_ALLOW_SCREENSHOTS=true
BROWSER_ALLOW_DOWNLOADS=false

BROWSER_DOWNLOAD_PATH="storage/downloads"


# ============================================================
# 15. CODE AGENT CONFIGURATION
# ============================================================

CODE_AGENT_ENABLED=true

CODE_AGENT_SANDBOX_ENABLED=true
CODE_AGENT_ALLOW_FILE_WRITE=true
CODE_AGENT_ALLOW_FILE_DELETE=false

CODE_AGENT_REQUIRE_SECURITY_FOR_EXECUTION=true

CODE_AGENT_SUPPORTED_LANGUAGES="python,javascript,typescript,html,css,json,yaml,sql,bash"

CODE_AGENT_WORKSPACE_PATH="workspace/code"
CODE_AGENT_MAX_FILE_SIZE_MB=10

CODE_AGENT_EXECUTION_TIMEOUT_SECONDS=60


# ============================================================
# 16. VISUAL AGENT CONFIGURATION
# ============================================================

VISUAL_AGENT_ENABLED=true

VISUAL_AGENT_ALLOW_IMAGE_ANALYSIS=true
VISUAL_AGENT_ALLOW_SCREEN_ANALYSIS=true
VISUAL_AGENT_ALLOW_OCR=true

VISUAL_AGENT_OCR_PROVIDER="local"

VISUAL_AGENT_MAX_IMAGE_SIZE_MB=20

VISUAL_STORAGE_PATH="storage/visual"


# ============================================================
# 17. WORKFLOW AGENT CONFIGURATION
# ============================================================

WORKFLOW_AGENT_ENABLED=true

WORKFLOW_MAX_STEPS=100
WORKFLOW_MAX_PARALLEL_TASKS=5

WORKFLOW_REQUIRE_SECURITY_FOR_AUTOMATIONS=true
WORKFLOW_STORE_TASK_HISTORY=true

WORKFLOW_RETRY_ATTEMPTS=3
WORKFLOW_RETRY_DELAY_SECONDS=5


# ============================================================
# 18. HOLOGRAM AGENT CONFIGURATION
# ============================================================

HOLOGRAM_AGENT_ENABLED=false

HOLOGRAM_RENDER_PROVIDER="none"
HOLOGRAM_OUTPUT_MODE="dashboard"

HOLOGRAM_ALLOW_3D_RENDERING=false
HOLOGRAM_STORAGE_PATH="storage/hologram"


# ============================================================
# 19. CALL AGENT CONFIGURATION
# ============================================================

CALL_AGENT_ENABLED=false

CALL_PROVIDER="none"

# Examples:
# twilio | telnyx | vonage | custom | none
CALL_PHONE_NUMBER="replace_with_calling_number"

CALL_API_KEY="replace_with_call_api_key"
CALL_API_SECRET="replace_with_call_api_secret"

CALL_RECORDING_ENABLED=false
CALL_TRANSCRIPTION_ENABLED=false

CALL_REQUIRE_SECURITY_APPROVAL=true
CALL_REQUIRE_USER_CONFIRMATION=true

CALL_ALLOWED_COUNTRIES="US,CA,GB,PK"
CALL_BLOCKED_COUNTRIES=""

CALL_MAX_DURATION_SECONDS=900


# ============================================================
# 20. BUSINESS AGENT CONFIGURATION
# ============================================================

BUSINESS_AGENT_ENABLED=true

BUSINESS_AGENT_ALLOW_CRM_TASKS=true
BUSINESS_AGENT_ALLOW_LEAD_ANALYSIS=true
BUSINESS_AGENT_ALLOW_REPORT_GENERATION=true

BUSINESS_AGENT_REQUIRE_SECURITY_FOR_EXTERNAL_MESSAGES=true

CRM_PROVIDER="none"
CRM_API_KEY="replace_with_crm_api_key"
CRM_BASE_URL="replace_with_crm_base_url"


# ============================================================
# 21. FINANCE AGENT CONFIGURATION
# ============================================================

FINANCE_AGENT_ENABLED=true

FINANCE_AGENT_ALLOW_ANALYSIS=true
FINANCE_AGENT_ALLOW_REPORTS=true

# Must stay false unless explicitly protected by Security Agent.
FINANCE_AGENT_ALLOW_REAL_TRANSACTIONS=false

FINANCE_REQUIRE_SECURITY_APPROVAL=true

PAYMENT_PROVIDER="stripe"
PAYMENT_SECRET_KEY="replace_with_payment_secret_key"
PAYMENT_WEBHOOK_SECRET="replace_with_payment_webhook_secret"

CURRENCY_DEFAULT="USD"


# ============================================================
# 22. CREATOR AGENT CONFIGURATION
# ============================================================

CREATOR_AGENT_ENABLED=true

CREATOR_ALLOW_TEXT_GENERATION=true
CREATOR_ALLOW_IMAGE_PROMPTS=true
CREATOR_ALLOW_VIDEO_PROMPTS=true
CREATOR_ALLOW_SOCIAL_CONTENT=true

CREATOR_STORAGE_PATH="storage/creator"

CREATOR_DEFAULT_BRAND_NAME="Digital Promotix"


# ============================================================
# 23. AI MODEL PROVIDERS
# ============================================================

DEFAULT_LLM_PROVIDER="openai"
DEFAULT_LLM_MODEL="gpt-4.1"

OPENAI_API_KEY="replace_with_openai_api_key"
OPENAI_ORG_ID="replace_with_openai_org_id"

ANTHROPIC_API_KEY="replace_with_anthropic_api_key"
GOOGLE_AI_API_KEY="replace_with_google_ai_api_key"

LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL="http://localhost:11434"
LOCAL_LLM_MODEL="llama3"

LLM_REQUEST_TIMEOUT_SECONDS=120
LLM_MAX_OUTPUT_TOKENS=4096

LLM_TEMPERATURE=0.3


# ============================================================
# 24. FILE STORAGE
# ============================================================

STORAGE_BACKEND="local"

# Allowed values:
# local | s3 | gcs | azure
LOCAL_STORAGE_PATH="storage"

UPLOADS_PATH="storage/uploads"
EXPORTS_PATH="storage/exports"
LOGS_PATH="storage/logs"

MAX_UPLOAD_SIZE_MB=50

S3_BUCKET_NAME="replace_with_s3_bucket"
S3_ACCESS_KEY_ID="replace_with_s3_access_key"
S3_SECRET_ACCESS_KEY="replace_with_s3_secret_key"
S3_REGION="us-east-1"

GCS_BUCKET_NAME="replace_with_gcs_bucket"
GCS_CREDENTIALS_JSON_PATH="replace_with_gcs_credentials_path"

AZURE_STORAGE_CONNECTION_STRING="replace_with_azure_storage_connection_string"
AZURE_STORAGE_CONTAINER="replace_with_azure_container"


# ============================================================
# 25. DASHBOARD / ANALYTICS
# ============================================================

DASHBOARD_ENABLED=true

DASHBOARD_ANALYTICS_ENABLED=true
DASHBOARD_SHOW_AGENT_STATUS=true
DASHBOARD_SHOW_TASK_HISTORY=true
DASHBOARD_SHOW_AUDIT_LOGS=true
DASHBOARD_SHOW_USAGE_METRICS=true

ANALYTICS_RETENTION_DAYS=365

USAGE_TRACKING_ENABLED=true
USAGE_TRACKING_BY_USER=true
USAGE_TRACKING_BY_WORKSPACE=true
USAGE_TRACKING_BY_AGENT=true


# ============================================================
# 26. AUDIT LOGS
# ============================================================

AUDIT_LOGS_ENABLED=true

AUDIT_LOG_LEVEL="INFO"

AUDIT_LOG_STORAGE_BACKEND="database"

AUDIT_LOG_INCLUDE_USER_ID=true
AUDIT_LOG_INCLUDE_WORKSPACE_ID=true
AUDIT_LOG_INCLUDE_AGENT_NAME=true
AUDIT_LOG_INCLUDE_TASK_ID=true
AUDIT_LOG_INCLUDE_SECURITY_STATUS=true

AUDIT_LOG_RETENTION_DAYS=730

AUDIT_LOG_SENSITIVE_DATA_REDACTION=true


# ============================================================
# 27. TASK HISTORY
# ============================================================

TASK_HISTORY_ENABLED=true

TASK_HISTORY_STORE_INPUT=true
TASK_HISTORY_STORE_OUTPUT=true
TASK_HISTORY_STORE_METADATA=true

TASK_HISTORY_REDACT_SECRETS=true

TASK_HISTORY_RETENTION_DAYS=365

TASK_ID_PREFIX="task"


# ============================================================
# 28. EMAIL / NOTIFICATIONS
# ============================================================

EMAIL_PROVIDER="smtp"

SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USERNAME="replace_with_smtp_username"
SMTP_PASSWORD="replace_with_smtp_password"
SMTP_USE_TLS=true

EMAIL_FROM_NAME="William AI"
EMAIL_FROM_ADDRESS="no-reply@example.com"

NOTIFICATIONS_ENABLED=true
NOTIFICATION_CHANNELS="email,dashboard"

ADMIN_NOTIFICATION_EMAIL="admin@example.com"


# ============================================================
# 29. WEBHOOKS
# ============================================================

WEBHOOKS_ENABLED=true

WEBHOOK_SECRET="replace_with_webhook_secret"

WEBHOOK_TIMEOUT_SECONDS=20
WEBHOOK_RETRY_ATTEMPTS=3

WEBHOOK_ALLOWED_EVENTS="task.created,task.completed,task.failed,agent.started,agent.completed,security.approval_required"


# ============================================================
# 30. SUBSCRIPTIONS / BILLING
# ============================================================

BILLING_ENABLED=false

STRIPE_PUBLIC_KEY="replace_with_stripe_public_key"
STRIPE_SECRET_KEY="replace_with_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="replace_with_stripe_webhook_secret"

PLAN_FREE_AGENT_LIMIT=3
PLAN_STARTER_AGENT_LIMIT=6
PLAN_PRO_AGENT_LIMIT=14
PLAN_BUSINESS_AGENT_LIMIT=25
PLAN_ENTERPRISE_AGENT_LIMIT=100

PLAN_FREE_TASK_LIMIT_MONTHLY=100
PLAN_STARTER_TASK_LIMIT_MONTHLY=1000
PLAN_PRO_TASK_LIMIT_MONTHLY=10000
PLAN_BUSINESS_TASK_LIMIT_MONTHLY=50000
PLAN_ENTERPRISE_TASK_LIMIT_MONTHLY=1000000


# ============================================================
# 31. RATE LIMITS
# ============================================================

GLOBAL_RATE_LIMIT_ENABLED=true

GLOBAL_RATE_LIMIT_REQUESTS_PER_MINUTE=120
GLOBAL_RATE_LIMIT_TASKS_PER_HOUR=500

USER_RATE_LIMIT_REQUESTS_PER_MINUTE=60
WORKSPACE_RATE_LIMIT_TASKS_PER_HOUR=250

AGENT_RATE_LIMIT_TASKS_PER_MINUTE=30


# ============================================================
# 32. LOGGING
# ============================================================

LOG_LEVEL="INFO"

LOG_FORMAT="json"

LOG_TO_CONSOLE=true
LOG_TO_FILE=true

LOG_FILE_PATH="storage/logs/william.log"

LOG_ROTATION_ENABLED=true
LOG_MAX_FILE_SIZE_MB=20
LOG_BACKUP_COUNT=10

LOG_REDACT_SECRETS=true


# ============================================================
# 33. DEVELOPMENT / TESTING
# ============================================================

TESTING=false

TEST_DATABASE_URL="sqlite:///./test_william_ai.db"

MOCK_AI_PROVIDER=false
MOCK_SECURITY_APPROVALS=false
MOCK_EXTERNAL_APIS=true

ENABLE_SWAGGER_DOCS=true
ENABLE_REDOC=true

SEED_DEMO_DATA=false

DEMO_USER_EMAIL="demo@example.com"
DEMO_USER_PASSWORD="replace_with_demo_password"


# ============================================================
# 34. PRODUCTION SAFETY
# ============================================================

PRODUCTION_FORCE_HTTPS=true

PRODUCTION_DISABLE_DEBUG=true
PRODUCTION_REQUIRE_STRONG_SECRETS=true

PRODUCTION_BLOCK_MOCK_APIS=true
PRODUCTION_BLOCK_SQLITE=false

PRODUCTION_ENABLE_SECURITY_HEADERS=true

TRUSTED_PROXIES=""

ENABLE_REQUEST_ID=true

REQUEST_ID_HEADER="X-Request-ID"


# ============================================================
# 35. BACKUP / EXPORT
# ============================================================

BACKUPS_ENABLED=false

BACKUP_STORAGE_BACKEND="local"
BACKUP_PATH="storage/backups"

BACKUP_RETENTION_DAYS=30

AUTO_BACKUP_ENABLED=false
AUTO_BACKUP_INTERVAL_HOURS=24

EXPORT_REQUIRE_SECURITY_APPROVAL=true


# ============================================================
# 36. INTEGRATIONS PLACEHOLDERS
# ============================================================

GOOGLE_CLIENT_ID="replace_with_google_client_id"
GOOGLE_CLIENT_SECRET="replace_with_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:8000/api/auth/google/callback"

MICROSOFT_CLIENT_ID="replace_with_microsoft_client_id"
MICROSOFT_CLIENT_SECRET="replace_with_microsoft_client_secret"
MICROSOFT_REDIRECT_URI="http://localhost:8000/api/auth/microsoft/callback"

SLACK_BOT_TOKEN="replace_with_slack_bot_token"
SLACK_SIGNING_SECRET="replace_with_slack_signing_secret"

DISCORD_BOT_TOKEN="replace_with_discord_bot_token"

TWILIO_ACCOUNT_SID="replace_with_twilio_account_sid"
TWILIO_AUTH_TOKEN="replace_with_twilio_auth_token"


# ============================================================
# 37. API KEYS FOR FUTURE PLUGINS
# ============================================================

PLUGIN_API_KEY="replace_with_plugin_api_key"

PLUGIN_SIGNATURE_SECRET="replace_with_plugin_signature_secret"

ALLOW_THIRD_PARTY_PLUGINS=false

PLUGIN_REQUIRE_SECURITY_REVIEW=true


# ============================================================
# 38. HEALTH CHECKS
# ============================================================

HEALTH_CHECK_ENABLED=true

HEALTH_CHECK_PATH="/health"

HEALTH_CHECK_INCLUDE_DATABASE=true
HEALTH_CHECK_INCLUDE_REDIS=true
HEALTH_CHECK_INCLUDE_AGENTS=true

READINESS_CHECK_PATH="/ready"

LIVENESS_CHECK_PATH="/live"


# ============================================================
# 39. FEATURE FLAGS
# ============================================================

FEATURE_VOICE_AGENT=true
FEATURE_BROWSER_AGENT=true
FEATURE_SYSTEM_AGENT=true
FEATURE_CODE_AGENT=true
FEATURE_MEMORY_AGENT=true
FEATURE_SECURITY_AGENT=true
FEATURE_VERIFICATION_AGENT=true
FEATURE_VISUAL_AGENT=true
FEATURE_WORKFLOW_AGENT=true
FEATURE_HOLOGRAM_AGENT=false
FEATURE_CALL_AGENT=false
FEATURE_BUSINESS_AGENT=true
FEATURE_FINANCE_AGENT=true
FEATURE_CREATOR_AGENT=true

FEATURE_MULTI_WORKSPACE=true
FEATURE_AGENT_MARKETPLACE=false
FEATURE_PLUGIN_AGENTS=true
FEATURE_TEAM_INVITES=true
FEATURE_AUDIT_EXPORTS=true


# ============================================================
# 40. FINAL SAFETY NOTES
# ============================================================

# This file is safe to commit because it contains placeholders only.
# Never commit your real .env file.
# Use .gitignore to exclude:
# .env
# *.key
# *.pem
# credentials.json
# service-account.json
# storage/
# logs/
# backups/

ENV_FILE_COMPLETE=true