WILLIAM_WORKFLOW_ENTERPRISE_TEMPLATE_LIMIT=10000
WILLIAM_WORKFLOW_FREE_TEMPLATE_LIMIT=5
WILLIAM_WORKFLOW_MAX_RUN_INPUT_BYTES=100000
WILLIAM_WORKFLOW_MAX_SEARCH_LIMIT=100
WILLIAM_WORKFLOW_MAX_TEMPLATE_STEPS=50
WILLIAM_WORKFLOW_MAX_WEBHOOK_PAYLOAD_BYTES=250000
